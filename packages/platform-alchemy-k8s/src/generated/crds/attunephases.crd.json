{
  "apiVersion": "apiextensions.k8s.io/v1",
  "kind": "CustomResourceDefinition",
  "metadata": {
    "name": "attunephases.attune.dev"
  },
  "spec": {
    "group": "attune.dev",
    "scope": "Namespaced",
    "names": {
      "plural": "attunephases",
      "singular": "attunephase",
      "kind": "AttunePhase",
      "shortNames": [
        "adphase"
      ]
    },
    "versions": [
      {
        "name": "v1alpha1",
        "served": true,
        "storage": true,
        "schema": {
          "openAPIV3Schema": {
            "type": "object",
            "properties": {
              "spec": {
                "type": "object",
                "properties": {
                  "runId": {
                    "type": "string"
                  },
                  "phase": {
                    "type": "string",
                    "enum": [
                      "discovery",
                      "indexing",
                      "joern-query",
                      "evidence-scoring",
                      "report-writing"
                    ]
                  },
                  "dependsOn": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "expectedArtifactRefs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "runId",
                  "phase"
                ],
                "additionalProperties": false
              },
              "status": {
                "type": "object",
                "properties": {
                  "phase": {
                    "type": "string",
                    "enum": [
                      "Pending",
                      "Blocked",
                      "Running",
                      "Succeeded",
                      "Failed"
                    ]
                  },
                  "conditions": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string"
                        },
                        "status": {
                          "type": "string",
                          "enum": [
                            "True",
                            "False",
                            "Unknown"
                          ]
                        },
                        "reason": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string"
                        },
                        "observedGeneration": {
                          "type": "number"
                        },
                        "lastTransitionTime": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "type",
                        "status"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "startedAt": {
                    "type": "string"
                  },
                  "completedAt": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            }
          }
        }
      }
    ]
  }
}
