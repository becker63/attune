{
  "apiVersion": "apiextensions.k8s.io/v1",
  "kind": "CustomResourceDefinition",
  "metadata": {
    "name": "attunebudgets.attune.dev"
  },
  "spec": {
    "group": "attune.dev",
    "scope": "Namespaced",
    "names": {
      "plural": "attunebudgets",
      "singular": "attunebudget",
      "kind": "AttuneBudget",
      "shortNames": [
        "adbudget"
      ]
    },
    "versions": [
      {
        "name": "v1alpha1",
        "served": true,
        "storage": true,
        "schema": {
          "openAPIV3Schema": {
            "type": "object",
            "properties": {
              "spec": {
                "type": "object",
                "properties": {
                  "runId": {
                    "type": "string"
                  },
                  "resourceClass": {
                    "type": "string"
                  },
                  "maxCpu": {
                    "type": "string"
                  },
                  "maxMemory": {
                    "type": "string"
                  },
                  "maxDurationSeconds": {
                    "type": "number"
                  },
                  "maxTokens": {
                    "type": "number"
                  },
                  "maxGpuSeconds": {
                    "type": "number"
                  }
                },
                "required": [
                  "runId",
                  "resourceClass"
                ],
                "additionalProperties": false
              },
              "status": {
                "type": "object",
                "properties": {
                  "phase": {
                    "type": "string",
                    "enum": [
                      "Pending",
                      "Reserved",
                      "Exceeded",
                      "Released"
                    ]
                  },
                  "conditions": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string"
                        },
                        "status": {
                          "type": "string",
                          "enum": [
                            "True",
                            "False",
                            "Unknown"
                          ]
                        },
                        "reason": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string"
                        },
                        "observedGeneration": {
                          "type": "number"
                        },
                        "lastTransitionTime": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "type",
                        "status"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "reserved": {
                    "type": "boolean"
                  },
                  "spentCpuSeconds": {
                    "type": "number"
                  },
                  "spentTokens": {
                    "type": "number"
                  }
                },
                "additionalProperties": false
              }
            }
          }
        }
      }
    ]
  }
}
