{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "packages/*": {}
  },
  "ignore": [
    "packages/*/src/generated/**",
    "packages/**/*.generated.ts"
  ],
  "ignoreDependencies": [
    "@nx/js",
    "@nx/workspace",
    "jscpd",
    "madge"
  ],
  "ignoreBinaries": [
    "arion",
    "java",
    "javac",
    "nix",
    "openspec",
    "tokei"
  ]
}
