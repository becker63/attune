{
  "name": "home-deployment",
  "root": "packages/home-deployment",
  "sourceRoot": "packages/home-deployment/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "packages/home-deployment",
        "command": "pnpm exec tsup src/index.ts src/alchemy.ts --format esm,cjs --dts --sourcemap --clean"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/home-deployment",
        "command": "pnpm exec tsgo --noEmit"
      }
    },
    "typecheck:classic": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/home-deployment",
        "command": "pnpm exec tsc --noEmit"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/home-deployment",
        "command": "pnpm exec vitest run"
      }
    }
  }
}
