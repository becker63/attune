{
  "$schema": "../../node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "plugins": [
    "@stryker-mutator/vitest-runner",
    "@stryker-mutator/typescript-checker"
  ],
  "testRunner": "vitest",
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "mutate": [
    "src/artifacts/evidence-matrix.ts",
    "src/permissions/permission-decision.ts"
  ],
  "ignoreStatic": true,
  "incremental": true,
  "incrementalFile": "../../reports/stryker-attune-pi-agent-incremental.json",
  "vitest": {
    "configFile": "vitest.config.ts",
    "dir": ".",
    "related": false
  },
  "coverageAnalysis": "perTest",
  "reporters": ["clear-text", "progress"],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 0
  },
  "concurrency": 2,
  "timeoutMS": 10000
}
