{
  "name": "@attune/nx",
  "version": "0.0.0",
  "description": "Attune workspace Nx generators and source-shape helpers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./generators.json": "./generators.json"
  },
  "generators": "./generators.json",
  "files": [
    "dist",
    "generators.json",
    "src/generators/**/schema.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
