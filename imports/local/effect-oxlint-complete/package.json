{
  "name": "oxlint-plugin-effect-complete",
  "version": "0.0.0",
  "description": "Complete Effect oxlint plugin merging effect-oxlint rules with haskellish closed-world discipline",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "file:."
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./plugin": {
      "import": {
        "types": "./dist/plugin.d.ts",
        "default": "./dist/plugin.js"
      }
    },
    "./presets/*": {
      "import": {
        "types": "./dist/presets/*.d.ts",
        "default": "./dist/presets/*.js"
      }
    }
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsdown",
    "typecheck": "oxlint --type-aware --type-check",
    "lint": "oxlint --type-aware --type-check",
    "lint:ox": "oxlint --type-aware --type-check",
    "lint:effect": "effect-language-service diagnostics --project tsconfig.json --lspconfig \"$(cat .effect-lsp.json)\"",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "bun test",
    "gate": "concurrently -n type,style,test -c blue,yellow,green \"bun run typecheck\" \"bun run lint\" \"bun run test\"",
    "codegen": "bun run scripts/codegen.ts",
    "add-rule": "bun run scripts/add-rule.ts",
    "version": "changeset version",
    "release": "bun run build && changeset publish",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "effect": "4.0.0-beta.78",
    "effect-oxlint": "^0.3.2"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@effect/language-service": "latest",
    "@effect/vitest": "latest",
    "@types/bun": "latest",
    "@types/node": "latest",
    "@typescript/native-preview": "latest",
    "concurrently": "latest",
    "lefthook": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "oxlint-tsgolint": "latest",
    "tsdown": "^0.22.0",
    "typescript": "latest",
    "unrun": "^0.3.0",
    "vitest": "latest"
  },
  "packageManager": "bun@1.3.13"
}
