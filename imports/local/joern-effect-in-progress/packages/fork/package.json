{
  "name": "@attune/fork",
  "version": "0.0.0",
  "description": "Attune Fork: phase-aware static analysis engine.",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./presets/*": {
      "types": "./dist/presets/*.d.ts",
      "import": "./dist/presets/*.js"
    }
  },
  "bin": {
    "attune-fork": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "fork": "tsx src/cli.ts",
    "lint": "pnpm --workspace-root fork:all"
  },
  "dependencies": {
    "@attune/eventing": "workspace:*",
    "effect": "4.0.0-beta.78",
    "effect-oxlint": "^0.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "fast-check": "^3.23.2",
    "oxlint": "^1.69.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  }
}
