{
  "$schema": "http://json-schema.org/schema",
  "$id": "SyncJoernTemplatesGeneratorSchema",
  "title": "Sync Joern Templates",
  "type": "object",
  "properties": {
    "directory": {
      "type": "string",
      "description": "Directory containing Joern template modules.",
      "default": "src/joern/templates"
    },
    "registry": {
      "type": "string",
      "description": "Generated template registry file.",
      "default": "src/joern/templates/TemplateRegistry.generated.ts"
    },
    "export": {
      "type": "boolean",
      "description": "Export the generated registry from the template barrel.",
      "default": true
    }
  },
  "additionalProperties": false
}
