{
  "name": "home-deployment",
  "root": "packages/home-deployment",
  "sourceRoot": "packages/home-deployment/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "packages/home-deployment",
        "command": "../../node_modules/.bin/tsup src/index.ts src/alchemy.ts src/cli.ts --format esm,cjs --dts --sourcemap --clean"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/home-deployment",
        "command": "../../node_modules/.bin/tsgo --noEmit"
      }
    },
    "typecheck:classic": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/home-deployment",
        "command": "../../node_modules/.bin/tsc --noEmit"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/home-deployment",
        "command": "../../node_modules/.bin/vitest run"
      }
    },
    "plan": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/home-deployment",
        "command": "../../node_modules/.bin/tsx src/cli.ts plan"
      }
    },
    "status": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/home-deployment",
        "command": "../../node_modules/.bin/tsx src/cli.ts status"
      }
    },
    "reconcile": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/home-deployment",
        "command": "../../node_modules/.bin/tsx src/cli.ts reconcile"
      }
    }
  }
}
