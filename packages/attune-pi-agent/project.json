{
  "name": "attune-pi-agent",
  "root": "packages/attune-pi-agent",
  "sourceRoot": "packages/attune-pi-agent/src",
  "targets": {
    "build": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "targetProject": "attune-pi-agent",
        "tool": "bundler",
        "action": "build",
        "toolId": "tsup",
        "parameters": {
          "entryPoints": [
            "src/index.ts",
            "src/pi-extension.ts",
            "src/generators/spec/generator.ts",
            "src/generators/permission-policy/generator.ts",
            "src/generators/test-obligation/generator.ts",
            "src/generators/taskplane-task/generator.ts"
          ],
          "format": "esm,cjs",
          "dts": true,
          "sourcemap": true,
          "clean": true
        },
        "dryRun": false
      }
    },
    "typecheck": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "attune-pi-agent",
        "checks": [
          "typecheck"
        ],
        "dryRun": false
      }
    },
    "typecheck:classic": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "targetProject": "attune-pi-agent",
        "tool": "typescript",
        "action": "check",
        "toolId": "tsc",
        "parameters": {
          "classic": true
        },
        "dryRun": false
      }
    },
    "lint": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "attune-pi-agent",
        "checks": [
          "lint"
        ],
        "dryRun": false
      }
    },
    "test": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "attune-pi-agent",
        "checks": [
          "test"
        ],
        "dryRun": false
      }
    },
    "property": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "targetProject": "attune-pi-agent",
        "tool": "test-runner",
        "action": "test",
        "toolId": "vitest",
        "parameters": {
          "files": [
            "test/*.property.test.ts"
          ]
        },
        "evidenceOutputs": [
          ".attune/cache/property-evidence/attune-pi-agent"
        ],
        "dryRun": false
      }
    },
    "mutation": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "targetProject": "attune-pi-agent",
        "tool": "mutation",
        "action": "mutate",
        "toolId": "stryker",
        "parameters": {
          "config": "stryker.conf.json"
        },
        "resourceTier": "heavy",
        "evidenceOutputs": [
          ".attune/cache/mutation/attune-pi-agent"
        ],
        "dryRun": false
      }
    },
    "attune-check": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework project check surface. Runs workspace diagnostics through the stable attune-check verb.",
        "attune": {
          "tier": "public",
          "surface": "check"
        }
      },
      "options": {
        "targetProject": "attune-pi-agent",
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:attune-check"
          ]
        },
        "dryRun": false
      }
    },
    "attune-repair": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework project repair surface. Applies safe deterministic repairs through the stable attune-repair verb when available.",
        "attune": {
          "tier": "public",
          "surface": "repair",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "attune-pi-agent",
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "attune-pi-agent:attune:repair-registry",
            "attune-pi-agent:attune:repair-properties",
            "attune-pi-agent:attune:repair-type-guidance",
            "attune-pi-agent:attune:repair-evidence",
            "attune-pi-agent:attune:repair-generated"
          ]
        },
        "dryRun": false
      }
    },
    "attune:repair-registry": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for operation registry. Public agents should prefer attune-pi-agent:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "registry",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "attune-pi-agent",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "attune-pi-agent",
          "kind": "registry"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/attune-pi-agent/attune-operation-registry.ts"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/attune-pi-agent/attune-operation-registry.ts"
      ]
    },
    "attune:repair-properties": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for property registry. Public agents should prefer attune-pi-agent:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "properties",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "attune-pi-agent",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "attune-pi-agent",
          "kind": "properties"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/attune-pi-agent/attune-property-registry.ts"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/attune-pi-agent/attune-property-registry.ts"
      ]
    },
    "attune:repair-type-guidance": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for type-guidance. Public agents should prefer attune-pi-agent:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "type-guidance",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "attune-pi-agent",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "attune-pi-agent",
          "kind": "type-guidance"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/attune-pi-agent/attune-type-guidance.ts"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/attune-pi-agent/attune-type-guidance.ts"
      ]
    },
    "attune:repair-evidence": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for evidence scaffold. Public agents should prefer attune-pi-agent:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "evidence",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "attune-pi-agent",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "attune-pi-agent",
          "kind": "evidence"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/attune-pi-agent/attune-property-evidence.ts"
        ],
        "evidenceOutputs": [
          ".attune/cache/evidence/attune-pi-agent/evidence-scaffold.json"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/attune-pi-agent/attune-property-evidence.ts",
        "{workspaceRoot}/.attune/cache/evidence/attune-pi-agent/evidence-scaffold.json"
      ]
    },
    "attune:repair-generated": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for generated freshness. Public agents should prefer attune-pi-agent:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "generated",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "attune-pi-agent",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "attune-pi-agent",
          "kind": "generated"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/attune-pi-agent/generated-freshness.json"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/attune-pi-agent/generated-freshness.json"
      ]
    }
  }
}
