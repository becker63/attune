{
  "name": "attune-nx",
  "root": "packages/attune-nx",
  "sourceRoot": "packages/attune-nx/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "packages/attune-nx",
        "command": "../../node_modules/.bin/tsc -p tsconfig.build.json && node scripts/write-generator-cjs-wrappers.mjs"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/attune-nx",
        "command": "node ../../scripts/codex/pnpm.mjs exec tsgo --noEmit"
      }
    },
    "typecheck:classic": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/attune-nx",
        "command": "node ../../scripts/codex/pnpm.mjs exec tsc --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/codex/pnpm.mjs exec oxlint --config root-oxlintrc.json packages/attune-nx --quiet"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/attune-nx",
        "command": "../../node_modules/.bin/vitest run"
      }
    }
  }
}
