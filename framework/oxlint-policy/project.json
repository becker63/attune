{
  "name": "effect-oxlint-policy",
  "root": "framework/oxlint-policy",
  "sourceRoot": "framework/oxlint-policy/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "targetProject": "effect-oxlint-policy",
        "tool": "bundler",
        "action": "build",
        "toolId": "tsup",
        "parameters": {
          "entryPoints": [
            "src/index.ts"
          ],
          "format": "esm",
          "dts": true,
          "sourcemap": false,
          "clean": true,
          "outDir": "dist"
        },
        "dryRun": false
      }
    },
    "typecheck": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "dryRun": false,
        "tool": "typescript",
        "action": "check",
        "parameters": {
          "classic": true,
          "tsconfig": "tsconfig.json"
        }
      }
    },
    "test": {
      "executor": "@attune/nx:package-check",
      "options": {
        "dryRun": false,
        "checks": [
          "test"
        ]
      }
    },
    "attune-check": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework project check surface. Runs workspace diagnostics through the stable attune-check verb.",
        "attune": {
          "tier": "public",
          "surface": "check"
        }
      },
      "options": {
        "targetProject": "effect-oxlint-policy",
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:attune-check"
          ]
        },
        "dryRun": false
      }
    },
    "attune-repair": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework project repair surface. Applies safe deterministic repairs through the stable attune-repair verb when available.",
        "attune": {
          "tier": "public",
          "surface": "repair",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "effect-oxlint-policy",
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "effect-oxlint-policy:attune:repair-registry",
            "effect-oxlint-policy:attune:repair-properties",
            "effect-oxlint-policy:attune:repair-type-guidance",
            "effect-oxlint-policy:attune:repair-evidence",
            "effect-oxlint-policy:attune:repair-generated"
          ]
        },
        "dryRun": false
      }
    },
    "attune:repair-registry": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for operation registry. Public agents should prefer effect-oxlint-policy:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "registry",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "effect-oxlint-policy",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "effect-oxlint-policy",
          "kind": "registry"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/effect-oxlint-policy/attune-operation-registry.ts"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/effect-oxlint-policy/attune-operation-registry.ts"
      ]
    },
    "attune:repair-properties": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for property registry. Public agents should prefer effect-oxlint-policy:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "properties",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "effect-oxlint-policy",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "effect-oxlint-policy",
          "kind": "properties"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/effect-oxlint-policy/attune-property-registry.ts"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/effect-oxlint-policy/attune-property-registry.ts"
      ]
    },
    "attune:repair-type-guidance": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for type-guidance. Public agents should prefer effect-oxlint-policy:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "type-guidance",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "effect-oxlint-policy",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "effect-oxlint-policy",
          "kind": "type-guidance"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/effect-oxlint-policy/attune-type-guidance.ts"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/effect-oxlint-policy/attune-type-guidance.ts"
      ]
    },
    "attune:repair-evidence": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for evidence scaffold. Public agents should prefer effect-oxlint-policy:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "evidence",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "effect-oxlint-policy",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "effect-oxlint-policy",
          "kind": "evidence"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/effect-oxlint-policy/attune-property-evidence.ts"
        ],
        "evidenceOutputs": [
          ".attune/cache/evidence/effect-oxlint-policy/evidence-scaffold.json"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/effect-oxlint-policy/attune-property-evidence.ts",
        "{workspaceRoot}/.attune/cache/evidence/effect-oxlint-policy/evidence-scaffold.json"
      ]
    },
    "attune:repair-generated": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for generated freshness. Public agents should prefer effect-oxlint-policy:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "generated",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "effect-oxlint-policy",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "effect-oxlint-policy",
          "kind": "generated"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/effect-oxlint-policy/generated-freshness.json"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/effect-oxlint-policy/generated-freshness.json"
      ]
    }
  }
}
