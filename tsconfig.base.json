{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@attune/attuned-discovery": ["./packages/attuned-discovery/src/index.ts"],
      "@attune/cocoindex-effect": ["./packages/cocoindex-effect/src/index.ts"],
      "@attune/foldkit-ui": ["./packages/attune-foldkit/src/index.ts"],
      "@attune/home-deployment": ["./packages/home-deployment/src/index.ts"],
      "@attune/architecture-lint": ["./packages/attune-architecture-lint/src/index.ts"],
      "@attune/platform-alchemy-k8s": ["./packages/platform-alchemy-k8s/src/index.ts"],
      "@attune/pi-agent": ["./packages/attune-pi-agent/src/index.ts"],
      "joern-effect": ["./packages/joern-effect/src/index.ts"],
      "@attune/joern-effect-properties": ["./packages/joern-effect-properties/src/index.ts"],
      "@attune/nx": ["./packages/attune-nx/src/index.ts"]
    }
  }
}
