{
  "$schema": "http://json-schema.org/schema",
  "$id": "SyncK8sResourcesGeneratorSchema",
  "title": "Sync Kubernetes Resources",
  "type": "object",
  "properties": {
    "directory": {
      "type": "string",
      "description": "Directory containing Kubernetes resource modules.",
      "default": "src/resources"
    },
    "registry": {
      "type": "string",
      "description": "Generated resource registry file."
    },
    "export": {
      "type": "boolean",
      "description": "Update an index.ts barrel in the resource directory.",
      "default": true
    }
  },
  "additionalProperties": false
}
