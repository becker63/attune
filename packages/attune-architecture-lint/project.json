{
  "name": "attune-architecture-lint",
  "root": "packages/attune-architecture-lint",
  "sourceRoot": "packages/attune-architecture-lint/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "packages/attune-architecture-lint",
        "command": "../../node_modules/.bin/tsup src/index.ts src/cli.ts --format esm,cjs --dts --sourcemap --clean"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/attune-architecture-lint",
        "command": "../../node_modules/.bin/tsgo --noEmit"
      }
    },
    "typecheck:classic": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/attune-architecture-lint",
        "command": "../../node_modules/.bin/tsc --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node_modules/.bin/oxlint --config root-oxlintrc.json packages/attune-architecture-lint --quiet && node_modules/.bin/tsx packages/attune-architecture-lint/src/cli.ts"
      }
    },
    "scan": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node_modules/.bin/tsx packages/attune-architecture-lint/src/cli.ts"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/attune-architecture-lint",
        "command": "../../node_modules/.bin/vitest run"
      }
    }
  }
}
