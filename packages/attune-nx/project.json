{
  "name": "attune-nx",
  "root": "packages/attune-nx",
  "sourceRoot": "packages/attune-nx/src",
  "targets": {
    "build": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "targetProject": "attune-nx",
        "tool": "typescript",
        "action": "build",
        "toolId": "tsc",
        "parameters": {
          "tsconfig": "tsconfig.build.json",
          "postBuild": "attune-nx-generator-cjs-wrappers"
        },
        "dryRun": false
      }
    },
    "typecheck": {
      "executor": "@attune/nx:package-check",
      "options": {
        "dryRun": false,
        "checks": [
          "typecheck"
        ]
      }
    },
    "typecheck:classic": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "dryRun": false,
        "tool": "typescript",
        "action": "check",
        "parameters": {
          "classic": true
        }
      }
    },
    "lint": {
      "executor": "@attune/nx:package-check",
      "options": {
        "dryRun": false,
        "checks": [
          "lint"
        ]
      }
    },
    "test": {
      "executor": "@attune/nx:package-check",
      "options": {
        "dryRun": false,
        "checks": [
          "test"
        ]
      }
    }
  }
}
