{
  "apiVersion": "apiextensions.k8s.io/v1",
  "kind": "CustomResourceDefinition",
  "metadata": {
    "name": "attunediscoveryruns.attune.dev"
  },
  "spec": {
    "group": "attune.dev",
    "scope": "Namespaced",
    "names": {
      "plural": "attunediscoveryruns",
      "singular": "attunediscoveryrun",
      "kind": "AttuneDiscoveryRun",
      "shortNames": [
        "adrun"
      ]
    },
    "versions": [
      {
        "name": "v1alpha1",
        "served": true,
        "storage": true,
        "schema": {
          "openAPIV3Schema": {
            "type": "object",
            "properties": {
              "spec": {
                "type": "object",
                "properties": {
                  "runId": {
                    "type": "string"
                  },
                  "repoUrl": {
                    "type": "string"
                  },
                  "workerPoolRef": {
                    "type": "string"
                  },
                  "repoSandboxRef": {
                    "type": "string"
                  },
                  "resourceClass": {
                    "type": "string"
                  },
                  "phaseRefs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "policyRef": {
                    "type": "string"
                  },
                  "budgetRef": {
                    "type": "string"
                  }
                },
                "required": [
                  "runId",
                  "repoUrl",
                  "workerPoolRef",
                  "resourceClass"
                ],
                "additionalProperties": false
              },
              "status": {
                "type": "object",
                "properties": {
                  "phase": {
                    "type": "string",
                    "enum": [
                      "Pending",
                      "Admitted",
                      "Running",
                      "Succeeded",
                      "Failed"
                    ]
                  },
                  "conditions": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string"
                        },
                        "status": {
                          "type": "string",
                          "enum": [
                            "True",
                            "False",
                            "Unknown"
                          ]
                        },
                        "reason": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string"
                        },
                        "observedGeneration": {
                          "type": "number"
                        },
                        "lastTransitionTime": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "type",
                        "status"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "artifactRefs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "observedGeneration": {
                    "type": "number"
                  }
                },
                "additionalProperties": false
              }
            }
          }
        }
      }
    ]
  }
}
