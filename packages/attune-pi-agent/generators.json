{
  "$schema": "../../node_modules/nx/schemas/generators-schema.json",
  "generators": {
    "spec": {
      "factory": "./dist/generators/spec/generator",
      "schema": "./src/generators/spec/schema.json",
      "description": "Create a deterministic Attune Pi implementation spec draft."
    },
    "permission-policy": {
      "factory": "./dist/generators/permission-policy/generator",
      "schema": "./src/generators/permission-policy/schema.json",
      "description": "Create a deterministic deny-first Pi permission policy artifact."
    },
    "test-obligation": {
      "factory": "./dist/generators/test-obligation/generator",
      "schema": "./src/generators/test-obligation/schema.json",
      "description": "Create a deterministic test-obligation artifact."
    },
    "taskplane-task": {
      "factory": "./dist/generators/taskplane-task/generator",
      "schema": "./src/generators/taskplane-task/schema.json",
      "description": "Create a deterministic future Taskplane adapter task artifact."
    }
  }
}
