{
  "name": "@attune/home-deployment",
  "version": "0.0.0",
  "description": "Effect/Alchemy-shaped deployment graph for Attune home compute bootstrap.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./alchemy": {
      "types": "./dist/alchemy.d.ts",
      "import": "./dist/alchemy.js",
      "require": "./dist/alchemy.cjs"
    }
  },
  "bin": {
    "attune-home": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/alchemy.ts src/cli.ts --format esm,cjs --dts --sourcemap --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@attune/platform-alchemy-k8s": "workspace:*",
    "alchemy": "^0.93.12",
    "effect": "4.0.0-beta.78"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  }
}
