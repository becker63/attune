{
  "name": "joern-effect-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace for generated TypeScript and Effect bindings for Joern CPGQL.",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "nix run .#check",
    "test": "nix run .#check",
    "typecheck": "nix run .#check",
    "typecheck:fast": "tsgo --noEmit",
    "check-generated": "nix run .#check-generated",
    "generate": "nix run .#generate",
    "lint": "nix run .#check",
    "fork": "nix run .#check",
    "check": "nix run .#check",
    "property": "nix run .#property",
    "lab": "nix run .#lab"
  },
  "devDependencies": {
    "@attune/fork": "workspace:*",
    "@types/node": "^22.15.30",
    "@typescript/native-preview": "latest",
    "expect-type": "^1.2.1",
    "fast-check": "^3.23.2",
    "oxc-parser": "^0.135.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "prettier": "^3.5.3",
    "ts-morph": "^28.0.0",
    "tsd": "^0.32.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  }
}
