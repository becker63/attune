{
  "name": "attune-foldkit",
  "root": "packages/attune-foldkit",
  "sourceRoot": "packages/attune-foldkit/src",
  "targets": {
    "build": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "targetProject": "attune-foldkit",
        "tool": "vite",
        "action": "build",
        "toolId": "vite",
        "outputs": [
          "packages/attune-foldkit/dist"
        ],
        "dryRun": false
      }
    },
    "build:lib": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "targetProject": "attune-foldkit",
        "tool": "bundler",
        "action": "build",
        "toolId": "tsup",
        "parameters": {
          "entryPoints": [
            "src/index.ts"
          ],
          "format": "esm,cjs",
          "dts": true,
          "sourcemap": true,
          "clean": true
        },
        "dryRun": false
      }
    },
    "typecheck": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "attune-foldkit",
        "checks": [
          "typecheck"
        ],
        "dryRun": false
      }
    },
    "typecheck:classic": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "targetProject": "attune-foldkit",
        "tool": "typescript",
        "action": "check",
        "toolId": "tsc",
        "parameters": {
          "classic": true
        },
        "dryRun": false
      }
    },
    "lint": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "attune-foldkit",
        "checks": [
          "lint"
        ],
        "dryRun": false
      }
    },
    "serve": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "targetProject": "attune-foldkit",
        "tool": "vite",
        "action": "serve",
        "toolId": "vite",
        "parameters": {
          "host": "127.0.0.1",
          "port": 5174
        },
        "resourceTier": "external",
        "dryRun": false
      }
    },
    "test": {
      "dependsOn": [],
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "attune-foldkit",
        "checks": [
          "test"
        ],
        "dryRun": false
      }
    },
    "attune-check": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework project check surface. Runs workspace diagnostics through the stable attune-check verb.",
        "attune": {
          "tier": "public",
          "surface": "check"
        }
      },
      "options": {
        "targetProject": "attune-foldkit",
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:attune-check"
          ]
        },
        "dryRun": false
      }
    },
    "attune-repair": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework project repair surface. Applies safe deterministic repairs through the stable attune-repair verb when available.",
        "attune": {
          "tier": "public",
          "surface": "repair",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "attune-foldkit",
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:attune-repair"
          ]
        },
        "dryRun": false
      }
    }
  }
}
