{
  "name": "workspace",
  "root": ".",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec oxlint --config root-oxlintrc.json package.json project.json nx.json tsconfig.base.json packages --quiet"
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm exec nx run workspace:policy-fast"
        ],
        "parallel": false
      }
    },
    "source-bom-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/architecture/source-bom-check.mjs"
      }
    },
    "shape-conformance": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx packages/attune-architecture/src/shape-conformance-cli.ts"
      },
      "metadata": {
        "description": "Effect Schema-backed generator shape inventory and Source BOM conformance check."
      }
    },
    "package-contracts-check": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm exec nx run workspace:source-bom-check",
          "pnpm exec nx run workspace:shape-conformance",
          "pnpm exec nx run workspace:framework-policy-check"
        ],
        "parallel": false
      },
      "metadata": {
        "description": "Focused diagnostic target for package contract/source ownership and generator shape conformance during the Effect package-contract migration."
      }
    },
    "framework-policy-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx packages/attune-architecture/src/framework-policy-cli.ts"
      },
      "metadata": {
        "description": "Focused framework import-boundary and no checked-in protocol report policy check."
      }
    },
    "policy-install-hooks": {
      "executor": "nx:run-commands",
      "options": {
        "command": "git config core.hooksPath .githooks"
      },
      "metadata": {
        "description": "Install the repo-owned Nix/Nx Git hooks for commit and push validation."
      }
    },
    "policy-commit": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "bash nix/policy-hooks/secret-path-hygiene.sh",
          "bash nix/policy-hooks/undeclared-workflow-policy.sh",
          "bash nix/policy-hooks/touched-source-bom-ownership.sh",
          "bash nix/policy-hooks/openspec-feasible-validation.sh",
          "bash nix/policy-hooks/focused-architecture-lint.sh"
        ],
        "parallel": false
      },
      "metadata": {
        "description": "Default pre-commit policy gate for staged changes."
      }
    },
    "policy-push": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm exec nx run workspace:policy-fast"
        ],
        "parallel": false
      },
      "metadata": {
        "description": "Default pre-push policy gate."
      }
    },
    "arch:scan": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/architecture/scan.mjs"
      },
      "metadata": {
        "description": "Low-level architecture scanner used by workspace policy targets. Public workflows should use workspace:policy-fast, workspace:policy-proof-pressure, or workspace:package-contracts-check."
      }
    },
    "arch:deps": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec depcruise packages --config .dependency-cruiser.cjs --output-type err"
      }
    },
    "arch:cycles": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec madge packages --ts-config tsconfig.base.json --extensions ts,tsx --circular"
      }
    },
    "arch:unused": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec knip --config knip.json"
      }
    },
    "arch:complexity": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec eslint packages --config eslint.config.mjs --max-warnings 0"
      }
    },
    "arch:duplicates": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec jscpd --config .jscpd.json"
      }
    },
    "arch:types": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/architecture/ts-extended-diagnostics.mjs"
      }
    },
    "arch:churn": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/architecture/churn-complexity.mjs"
      }
    },
    "arch:mutation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec stryker run stryker.conf.json"
      },
      "metadata": {
        "description": "Explicit mutation-pressure architecture gate. Only workspace:policy-proof-pressure invokes this target."
      }
    },
    "policy-architecture": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm exec nx run attune-architecture:test",
          "pnpm exec nx run workspace:arch:scan",
          "pnpm exec nx run workspace:arch:deps",
          "pnpm exec nx run workspace:arch:cycles",
          "pnpm exec nx run workspace:arch:complexity",
          "pnpm exec nx run workspace:arch:duplicates",
          "pnpm exec nx run workspace:arch:types",
          "pnpm exec nx run workspace:arch:churn",
          "pnpm exec nx run effect-oxlint-policy:test",
          "pnpm exec nx run effect-oxlint-policy:build",
          "pnpm exec oxlint --config oxlint/effect-oxlint-policy.json package.json project.json nx.json tsconfig.base.json packages --quiet"
        ],
        "parallel": false
      },
      "metadata": {
        "description": "Internal compatibility aggregate retained during migration. Public workflows should use workspace:policy-fast, workspace:policy-proof-pressure, or workspace:package-contracts-check."
      }
    },
    "policy-proof-pressure": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm exec nx run workspace:package-contracts-check",
          "pnpm exec nx run attune-architecture:test",
          "pnpm exec nx run workspace:arch:scan",
          "pnpm exec nx run workspace:arch:deps",
          "pnpm exec nx run workspace:arch:cycles",
          "pnpm exec nx run workspace:arch:complexity",
          "pnpm exec nx run workspace:arch:duplicates",
          "pnpm exec nx run workspace:arch:types",
          "pnpm exec nx run workspace:arch:churn",
          "pnpm exec nx run effect-oxlint-policy:test",
          "pnpm exec nx run effect-oxlint-policy:build",
          "pnpm exec oxlint --config oxlint/effect-oxlint-policy.json package.json project.json nx.json tsconfig.base.json packages --quiet",
          "pnpm exec nx run workspace:arch:mutation"
        ],
        "parallel": false
      }
    },
    "policy-fast": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm exec nx graph --file=/tmp/attune-nx-graph.json",
          "pnpm exec nx run attune-nx:test",
          "pnpm exec nx run workspace:package-contracts-check",
          "pnpm exec nx run attune-architecture:test",
          "pnpm exec nx run workspace:arch:scan",
          "pnpm exec nx run workspace:arch:deps",
          "pnpm exec nx run workspace:arch:cycles",
          "pnpm exec nx run workspace:arch:complexity",
          "pnpm exec nx run workspace:arch:duplicates",
          "pnpm exec nx run workspace:arch:types",
          "pnpm exec nx run workspace:arch:churn",
          "pnpm exec nx run effect-oxlint-policy:test",
          "pnpm exec nx run effect-oxlint-policy:build",
          "pnpm exec oxlint --config oxlint/effect-oxlint-policy.json package.json project.json nx.json tsconfig.base.json packages --quiet",
          "node scripts/codex/verify-pr-completion.mjs"
        ],
        "parallel": false
      }
    },
    "policy-all": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm exec nx run workspace:policy-push",
          "pnpm exec nx run workspace:policy-proof-pressure"
        ],
        "parallel": false
      }
    },
    "codex-audit-prs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/codex/audit-pr-recovery.mjs"
      }
    }
  }
}
