{
  "name": "effect-oxlint-policy",
  "root": "packages/effect-oxlint-policy",
  "sourceRoot": "packages/effect-oxlint-policy/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "targetProject": "effect-oxlint-policy",
        "tool": "bundler",
        "action": "build",
        "toolId": "tsup",
        "parameters": {
          "entryPoints": [
            "src/index.ts"
          ],
          "format": "esm",
          "dts": true,
          "sourcemap": false,
          "clean": true,
          "outDir": "dist"
        },
        "dryRun": false
      }
    },
    "typecheck": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "dryRun": false,
        "tool": "typescript",
        "action": "check",
        "parameters": {
          "classic": true,
          "tsconfig": "tsconfig.json"
        }
      }
    },
    "test": {
      "executor": "@attune/nx:package-check",
      "options": {
        "dryRun": false,
        "checks": [
          "test"
        ]
      }
    }
  }
}
