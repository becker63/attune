{
  "name": "joern-effect",
  "root": "packages/joern-effect",
  "sourceRoot": "packages/joern-effect/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm exec tsup"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm exec tsgo --noEmit"
      }
    },
    "typecheck:classic": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm exec tsc --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "corepack pnpm exec oxlint --config root-oxlintrc.json packages/joern-effect --quiet"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm exec vitest run"
      }
    },
    "extract-cpg-schema": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/schema"],
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm run extract-schema:joern > schema/joern-cpg-schema.${JOERN_CPG_VERSION:-unknown}.json"
      }
    },
    "enrich-schema-docs": {
      "executor": "nx:run-commands",
      "inputs": ["{projectRoot}/schema/**/*", "{projectRoot}/scripts/enrichSchemaDocs.mjs"],
      "outputs": ["{projectRoot}/schema"],
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm exec tsx scripts/generationStage.ts enrich-schema-docs"
      }
    },
    "normalize-schema": {
      "executor": "nx:run-commands",
      "inputs": ["{projectRoot}/schema/**/*", "{projectRoot}/src/pure/codegen/normalizeSchema.ts"],
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm exec tsx scripts/generationStage.ts normalize-schema"
      }
    },
    "emit-schema-modules": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/pure/generated/schema.ts"],
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm exec tsx scripts/generationStage.ts emit-schema-modules"
      }
    },
    "emit-node-types": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/pure/generated/nodes.ts"],
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm exec tsx scripts/generationStage.ts emit-node-types"
      }
    },
    "emit-property-metadata": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/pure/generated/prop.ts"],
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm exec tsx scripts/generationStage.ts emit-property-metadata"
      }
    },
    "emit-traversal-dsl": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/pure/generated/cpg.ts", "{projectRoot}/src/pure/generated/traversal.ts"],
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm exec tsx scripts/generationStage.ts emit-traversal-dsl"
      }
    },
    "emit-template-registry": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/generated/TemplateRegistry.generated.ts"],
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm exec tsx scripts/generationStage.ts emit-template-registry"
      }
    },
    "emit-template-bindings": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/generated/TemplateBindings.generated.ts"],
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm exec tsx scripts/generationStage.ts emit-template-bindings"
      }
    },
    "emit-template-evidence": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/generated/TemplateEvidence.generated.ts"],
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm exec tsx scripts/generationStage.ts emit-template-evidence"
      }
    },
    "emit-fast-check-arbitraries": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/internal/generated"],
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm exec tsx scripts/generationStage.ts emit-fast-check-arbitraries"
      }
    },
    "emit-generated": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/pure/generated"],
      "options": {
        "cwd": "packages/joern-effect",
        "command": "JOERN_CPG_SCHEMA_JSON=\"${JOERN_CPG_SCHEMA_JSON:-schema/joern-cpg-schema.${JOERN_CPG_VERSION:-1.7.70}.json}\" corepack pnpm run generate"
      }
    },
    "render-readme": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/README.md"],
      "options": {
        "cwd": "packages/joern-effect",
        "command": "corepack pnpm run render-readme"
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/pure/generated", "{projectRoot}/README.md"],
      "options": {
        "commands": [
          "corepack pnpm exec nx run joern-effect:emit-generated",
          "corepack pnpm exec nx run joern-effect:render-readme"
        ],
        "parallel": false
      }
    },
    "check-generated": {
      "executor": "nx:run-commands",
      "dependsOn": ["generate"],
      "options": {
        "command": "git diff --exit-code -- packages/joern-effect/src/pure/generated packages/joern-effect/README.md packages/joern-effect/schema"
      }
    }
  }
}
