{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "framework-runtime",
  "projectType": "library",
  "root": "framework/runtime",
  "sourceRoot": "framework/runtime/src",
  "targets": {
    "typecheck": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "dryRun": false,
        "tool": "typescript",
        "action": "check",
        "parameters": {
          "classic": true,
          "tsconfig": "tsconfig.json"
        }
      }
    },
    "test": {
      "executor": "@attune/nx:package-check",
      "options": {
        "dryRun": false,
        "checks": [
          "test"
        ]
      }
    }
  },
  "tags": ["scope:framework", "attune:framework"]
}
