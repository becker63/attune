{
  "name": "attuned-discovery",
  "root": "packages/attuned-discovery",
  "sourceRoot": "packages/attuned-discovery/src",
  "targets": {
    "build": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "targetProject": "attuned-discovery",
        "tool": "bundler",
        "action": "build",
        "toolId": "tsup",
        "parameters": {
          "entryPoints": [
            "src/index.ts"
          ],
          "format": "esm,cjs",
          "dts": true,
          "sourcemap": true,
          "clean": true
        },
        "dryRun": false
      }
    },
    "typecheck": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "attuned-discovery",
        "checks": [
          "typecheck"
        ],
        "dryRun": false
      }
    },
    "typecheck:classic": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "targetProject": "attuned-discovery",
        "tool": "typescript",
        "action": "check",
        "toolId": "tsc",
        "parameters": {
          "classic": true
        },
        "dryRun": false
      }
    },
    "lint": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "attuned-discovery",
        "checks": [
          "lint"
        ],
        "dryRun": false
      }
    },
    "test": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "attuned-discovery",
        "checks": [
          "test"
        ],
        "dryRun": false
      }
    }
  }
}
