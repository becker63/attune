{
  "name": "joern-effect",
  "root": "packages/joern-effect",
  "sourceRoot": "packages/joern-effect/src",
  "targets": {
    "build": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "targetProject": "joern-effect",
        "tool": "bundler",
        "action": "build",
        "toolId": "tsup",
        "parameters": {
          "entryPoints": [],
          "format": "esm,cjs",
          "dts": true,
          "sourcemap": true,
          "clean": true
        },
        "dryRun": false
      }
    },
    "typecheck": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "joern-effect",
        "checks": [
          "typecheck"
        ],
        "dryRun": false
      }
    },
    "typecheck:classic": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "targetProject": "joern-effect",
        "tool": "typescript",
        "action": "check",
        "toolId": "tsc",
        "parameters": {
          "classic": true
        },
        "dryRun": false
      }
    },
    "lint": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "joern-effect",
        "checks": [
          "lint"
        ],
        "dryRun": false
      }
    },
    "test": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "joern-effect",
        "checks": [
          "test"
        ],
        "dryRun": false
      }
    },
    "extract-cpg-schema": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/schema"
      ],
      "options": {
        "targetProject": "joern-effect",
        "tool": "joern",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "extract-cpg-schema"
        },
        "dryRun": false
      }
    },
    "enrich-schema-docs": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/schema"
      ],
      "options": {
        "targetProject": "joern-effect",
        "tool": "joern",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "enrich-schema-docs"
        },
        "dryRun": false
      }
    },
    "normalize-schema": {
      "executor": "@attune/nx:toolchain",
      "outputs": [],
      "options": {
        "targetProject": "joern-effect",
        "tool": "joern",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "normalize-schema"
        },
        "dryRun": false
      }
    },
    "emit-schema-modules": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/pure/generated/schema.ts"
      ],
      "options": {
        "targetProject": "joern-effect",
        "tool": "joern",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "emit-schema-modules"
        },
        "dryRun": false
      }
    },
    "emit-node-types": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/pure/generated/nodes.ts"
      ],
      "options": {
        "targetProject": "joern-effect",
        "tool": "joern",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "emit-node-types"
        },
        "dryRun": false
      }
    },
    "emit-property-metadata": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/pure/generated/prop.ts"
      ],
      "options": {
        "targetProject": "joern-effect",
        "tool": "joern",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "emit-property-metadata"
        },
        "dryRun": false
      }
    },
    "emit-traversal-dsl": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/pure/generated/cpg.ts",
        "{projectRoot}/src/pure/generated/traversal.ts"
      ],
      "options": {
        "targetProject": "joern-effect",
        "tool": "joern",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "emit-traversal-dsl"
        },
        "dryRun": false
      }
    },
    "emit-template-registry": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/generated/TemplateRegistry.generated.ts"
      ],
      "options": {
        "targetProject": "joern-effect",
        "tool": "joern",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "emit-template-registry"
        },
        "dryRun": false
      }
    },
    "emit-template-bindings": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/generated/TemplateBindings.generated.ts"
      ],
      "options": {
        "targetProject": "joern-effect",
        "tool": "joern",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "emit-template-bindings"
        },
        "dryRun": false
      }
    },
    "emit-template-evidence": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/generated/TemplateEvidence.generated.ts"
      ],
      "options": {
        "targetProject": "joern-effect",
        "tool": "joern",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "emit-template-evidence"
        },
        "dryRun": false
      }
    },
    "emit-fast-check-arbitraries": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/internal/generated"
      ],
      "options": {
        "targetProject": "joern-effect",
        "tool": "joern",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "emit-fast-check-arbitraries"
        },
        "dryRun": false
      }
    },
    "emit-generated": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/pure/generated"
      ],
      "options": {
        "targetProject": "joern-effect",
        "tool": "joern",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "emit-generated"
        },
        "dryRun": false
      }
    },
    "render-readme": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/README.md"
      ],
      "options": {
        "targetProject": "joern-effect",
        "tool": "joern",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "render-readme"
        },
        "dryRun": false
      }
    },
    "generate": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/pure/generated",
        "{projectRoot}/README.md"
      ],
      "options": {
        "tool": "workspace",
        "action": "check",
        "toolId": "joern-effect-generate",
        "parameters": {
          "targets": [
            "joern-effect:emit-generated",
            "joern-effect:render-readme"
          ]
        },
        "dryRun": false
      }
    },
    "check-generated": {
      "executor": "@attune/nx:generated",
      "dependsOn": [
        "generate"
      ],
      "options": {
        "targetProject": "joern-effect",
        "operation": "check",
        "artifact": "generator-shape",
        "outputs": [
          "packages/joern-effect/src/pure/generated",
          "packages/joern-effect/README.md",
          "packages/joern-effect/schema"
        ],
        "provenance": {
          "generatorName": "joern-effect:generationStage",
          "owner": "joern-effect"
        },
        "dryRun": false
      }
    },
    "attune-check": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework project check surface. Runs workspace diagnostics through the stable attune-check verb.",
        "attune": {
          "tier": "public",
          "surface": "check"
        }
      },
      "options": {
        "targetProject": "joern-effect",
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:attune-check"
          ]
        },
        "dryRun": false
      }
    },
    "attune-repair": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework project repair surface. Applies safe deterministic repairs through the stable attune-repair verb when available.",
        "attune": {
          "tier": "public",
          "surface": "repair",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "joern-effect",
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "joern-effect:attune:repair-registry",
            "joern-effect:attune:repair-properties",
            "joern-effect:attune:repair-type-guidance",
            "joern-effect:attune:repair-evidence",
            "joern-effect:attune:repair-generated"
          ]
        },
        "dryRun": false
      }
    },
    "attune:repair-registry": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for operation registry. Public agents should prefer joern-effect:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "registry",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "joern-effect",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "joern-effect",
          "kind": "registry"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/joern-effect/attune-operation-registry.ts"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/joern-effect/attune-operation-registry.ts"
      ]
    },
    "attune:repair-properties": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for property registry. Public agents should prefer joern-effect:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "properties",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "joern-effect",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "joern-effect",
          "kind": "properties"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/joern-effect/attune-property-registry.ts"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/joern-effect/attune-property-registry.ts"
      ]
    },
    "attune:repair-type-guidance": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for type-guidance. Public agents should prefer joern-effect:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "type-guidance",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "joern-effect",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "joern-effect",
          "kind": "type-guidance"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/joern-effect/attune-type-guidance.ts"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/joern-effect/attune-type-guidance.ts"
      ]
    },
    "attune:repair-evidence": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for evidence scaffold. Public agents should prefer joern-effect:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "evidence",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "joern-effect",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "joern-effect",
          "kind": "evidence"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/joern-effect/attune-property-evidence.ts"
        ],
        "evidenceOutputs": [
          ".attune/cache/evidence/joern-effect/evidence-scaffold.json"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/joern-effect/attune-property-evidence.ts",
        "{workspaceRoot}/.attune/cache/evidence/joern-effect/evidence-scaffold.json"
      ]
    },
    "attune:repair-generated": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for generated freshness. Public agents should prefer joern-effect:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "generated",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "joern-effect",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "joern-effect",
          "kind": "generated"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/joern-effect/generated-freshness.json"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/joern-effect/generated-freshness.json"
      ]
    }
  }
}
