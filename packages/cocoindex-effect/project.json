{
  "name": "cocoindex-effect",
  "root": "packages/cocoindex-effect",
  "sourceRoot": "packages/cocoindex-effect/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "packages/cocoindex-effect",
        "command": "pnpm exec tsup src/index.ts --format esm,cjs --dts --sourcemap --clean"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/cocoindex-effect",
        "command": "pnpm exec tsgo --noEmit"
      }
    },
    "typecheck:classic": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/cocoindex-effect",
        "command": "pnpm exec tsc --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec oxlint --config root-oxlintrc.json packages/cocoindex-effect --quiet"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/cocoindex-effect",
        "command": "pnpm exec vitest run"
      }
    },
    "inspect-cocoindex-mcp": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/generated/cocoindex-code-mcp.ts"],
      "options": {
        "cwd": "packages/cocoindex-effect",
        "command": "pnpm exec tsx scripts/generationStage.ts inspect-cocoindex-mcp"
      }
    },
    "emit-mcp-schema": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/generated/cocoindex-code-mcp.ts"],
      "options": {
        "cwd": "packages/cocoindex-effect",
        "command": "pnpm exec tsx scripts/generationStage.ts emit-mcp-schema"
      }
    },
    "scaffold-mcp-search-tool": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/cocoindex/tools/search.ts"],
      "options": {
        "command": "pnpm exec nx generate @attune/nx:cocoindex-mcp-tool search --directory packages/cocoindex-effect/src/cocoindex/tools --toolName search"
      }
    },
    "sync-mcp-tools": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/cocoindex/tools/ToolRegistry.generated.ts"],
      "options": {
        "command": "pnpm exec nx generate @attune/nx:sync-cocoindex-mcp-tools --directory packages/cocoindex-effect/src/cocoindex/tools --registry packages/cocoindex-effect/src/cocoindex/tools/ToolRegistry.generated.ts"
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/src/generated/cocoindex-code-mcp.ts",
        "{projectRoot}/src/cocoindex/tools/ToolRegistry.generated.ts"
      ],
      "options": {
        "commands": [
          "pnpm exec nx run cocoindex-effect:emit-mcp-schema",
          "pnpm exec nx run cocoindex-effect:sync-mcp-tools"
        ],
        "parallel": false
      }
    },
    "check-generated": {
      "executor": "nx:run-commands",
      "dependsOn": ["generate"],
      "options": {
        "command": "git diff --exit-code -- packages/cocoindex-effect/src/generated packages/cocoindex-effect/src/cocoindex/tools/ToolRegistry.generated.ts"
      }
    }
  }
}
