{
  "name": "cocoindex-effect",
  "root": "packages/cocoindex-effect",
  "sourceRoot": "packages/cocoindex-effect/src",
  "targets": {
    "build": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "targetProject": "cocoindex-effect",
        "tool": "bundler",
        "action": "build",
        "toolId": "tsup",
        "parameters": {
          "entryPoints": [
            "src/index.ts"
          ],
          "format": "esm,cjs",
          "dts": true,
          "sourcemap": true,
          "clean": true
        },
        "dryRun": false
      }
    },
    "typecheck": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "cocoindex-effect",
        "checks": [
          "typecheck"
        ],
        "dryRun": false
      }
    },
    "typecheck:classic": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "targetProject": "cocoindex-effect",
        "tool": "typescript",
        "action": "check",
        "toolId": "tsc",
        "parameters": {
          "classic": true
        },
        "dryRun": false
      }
    },
    "lint": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "cocoindex-effect",
        "checks": [
          "lint"
        ],
        "dryRun": false
      }
    },
    "test": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "cocoindex-effect",
        "checks": [
          "test"
        ],
        "dryRun": false
      }
    },
    "inspect-cocoindex-mcp": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/generated/cocoindex-code-mcp.ts"
      ],
      "options": {
        "targetProject": "cocoindex-effect",
        "tool": "generation-stage",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "inspect-cocoindex-mcp"
        },
        "dryRun": false
      }
    },
    "emit-mcp-schema": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/generated/cocoindex-code-mcp.ts"
      ],
      "options": {
        "targetProject": "cocoindex-effect",
        "tool": "generation-stage",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "emit-mcp-schema"
        },
        "dryRun": false
      }
    },
    "scaffold-mcp-search-tool": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/cocoindex/tools/search.ts"
      ],
      "options": {
        "targetProject": "cocoindex-effect",
        "tool": "nx",
        "action": "generate",
        "toolId": "@attune/nx:cocoindex-mcp-tool",
        "parameters": {
          "generator": "@attune/nx:cocoindex-mcp-tool",
          "arguments": [
            "search",
            "--directory",
            "packages/cocoindex-effect/src/cocoindex/tools",
            "--toolName",
            "search"
          ]
        },
        "dryRun": false
      }
    },
    "sync-mcp-tools": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/cocoindex/tools/ToolRegistry.generated.ts"
      ],
      "options": {
        "targetProject": "cocoindex-effect",
        "tool": "nx",
        "action": "generate",
        "toolId": "@attune/nx:sync-cocoindex-mcp-tools",
        "parameters": {
          "generator": "@attune/nx:sync-cocoindex-mcp-tools",
          "arguments": [
            "--directory",
            "packages/cocoindex-effect/src/cocoindex/tools",
            "--registry",
            "packages/cocoindex-effect/src/cocoindex/tools/ToolRegistry.generated.ts"
          ]
        },
        "dryRun": false
      }
    },
    "generate": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/generated/cocoindex-code-mcp.ts",
        "{projectRoot}/src/cocoindex/tools/ToolRegistry.generated.ts"
      ],
      "options": {
        "tool": "workspace",
        "action": "check",
        "toolId": "cocoindex-effect-generate",
        "parameters": {
          "targets": [
            "cocoindex-effect:emit-mcp-schema",
            "cocoindex-effect:sync-mcp-tools"
          ]
        },
        "dryRun": false
      }
    },
    "check-generated": {
      "executor": "@attune/nx:generated",
      "dependsOn": [
        "generate"
      ],
      "options": {
        "targetProject": "cocoindex-effect",
        "operation": "check",
        "artifact": "rpc-harness",
        "outputs": [
          "packages/cocoindex-effect/src/generated",
          "packages/cocoindex-effect/src/cocoindex/tools/ToolRegistry.generated.ts"
        ],
        "provenance": {
          "generatorName": "@attune/nx:sync-cocoindex-mcp-tools",
          "owner": "cocoindex-effect"
        },
        "dryRun": false
      }
    },
    "attune-check": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework project check surface. Runs workspace diagnostics through the stable attune-check verb.",
        "attune": {
          "tier": "public",
          "surface": "check"
        }
      },
      "options": {
        "targetProject": "cocoindex-effect",
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:attune-check"
          ]
        },
        "dryRun": false
      }
    },
    "attune-repair": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework project repair surface. Applies safe deterministic repairs through the stable attune-repair verb when available.",
        "attune": {
          "tier": "public",
          "surface": "repair",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "cocoindex-effect",
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "cocoindex-effect:attune:repair-registry",
            "cocoindex-effect:attune:repair-properties",
            "cocoindex-effect:attune:repair-type-guidance",
            "cocoindex-effect:attune:repair-evidence",
            "cocoindex-effect:attune:repair-generated"
          ]
        },
        "dryRun": false
      }
    },
    "attune:repair-registry": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for operation registry. Public agents should prefer cocoindex-effect:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "registry",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "cocoindex-effect",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "cocoindex-effect",
          "kind": "registry"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/cocoindex-effect/attune-operation-registry.ts"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/cocoindex-effect/attune-operation-registry.ts"
      ]
    },
    "attune:repair-properties": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for property registry. Public agents should prefer cocoindex-effect:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "properties",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "cocoindex-effect",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "cocoindex-effect",
          "kind": "properties"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/cocoindex-effect/attune-property-registry.ts"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/cocoindex-effect/attune-property-registry.ts"
      ]
    },
    "attune:repair-type-guidance": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for type-guidance. Public agents should prefer cocoindex-effect:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "type-guidance",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "cocoindex-effect",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "cocoindex-effect",
          "kind": "type-guidance"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/cocoindex-effect/attune-type-guidance.ts"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/cocoindex-effect/attune-type-guidance.ts"
      ]
    },
    "attune:repair-evidence": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for evidence scaffold. Public agents should prefer cocoindex-effect:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "evidence",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "cocoindex-effect",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "cocoindex-effect",
          "kind": "evidence"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/cocoindex-effect/attune-property-evidence.ts"
        ],
        "evidenceOutputs": [
          ".attune/cache/evidence/cocoindex-effect/evidence-scaffold.json"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/cocoindex-effect/attune-property-evidence.ts",
        "{workspaceRoot}/.attune/cache/evidence/cocoindex-effect/evidence-scaffold.json"
      ]
    },
    "attune:repair-generated": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for generated freshness. Public agents should prefer cocoindex-effect:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "generated",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "cocoindex-effect",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "cocoindex-effect",
          "kind": "generated"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/cocoindex-effect/generated-freshness.json"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/cocoindex-effect/generated-freshness.json"
      ]
    }
  }
}
