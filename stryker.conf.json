{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "plugins": [
    "@stryker-mutator/vitest-runner",
    "@stryker-mutator/typescript-checker"
  ],
  "testRunner": "vitest",
  "checkers": ["typescript"],
  "tsconfigFile": "packages/attuned-discovery/tsconfig.json",
  "mutate": [
    "packages/attuned-discovery/src/memory/read-model.ts",
    "packages/attuned-discovery/src/projection/read-model-projection.ts"
  ],
  "ignoreStatic": true,
  "incremental": true,
  "incrementalFile": "reports/stryker-attuned-discovery-incremental.json",
  "vitest": {
    "configFile": "packages/attuned-discovery/vitest.config.ts",
    "dir": "packages/attuned-discovery",
    "related": false
  },
  "coverageAnalysis": "perTest",
  "reporters": ["clear-text", "progress"],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 0
  },
  "concurrency": 2,
  "timeoutMS": 10000
}
