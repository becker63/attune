{
  "name": "attune-nx",
  "root": "packages/attune-nx",
  "sourceRoot": "packages/attune-nx/src",
  "targets": {
    "build": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "targetProject": "attune-nx",
        "tool": "typescript",
        "action": "build",
        "toolId": "tsc",
        "parameters": {
          "tsconfig": "tsconfig.build.json",
          "postBuild": "attune-nx-generator-cjs-wrappers"
        },
        "dryRun": false
      }
    },
    "typecheck": {
      "executor": "@attune/nx:package-check",
      "options": {
        "dryRun": false,
        "checks": [
          "typecheck"
        ]
      }
    },
    "typecheck:classic": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "dryRun": false,
        "tool": "typescript",
        "action": "check",
        "parameters": {
          "classic": true
        }
      }
    },
    "lint": {
      "executor": "@attune/nx:package-check",
      "options": {
        "dryRun": false,
        "checks": [
          "lint"
        ]
      }
    },
    "test": {
      "executor": "@attune/nx:package-check",
      "options": {
        "dryRun": false,
        "checks": [
          "test"
        ]
      }
    },
    "attune-check": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework project check surface. Runs workspace diagnostics through the stable attune-check verb.",
        "attune": {
          "tier": "public",
          "surface": "check"
        }
      },
      "options": {
        "targetProject": "attune-nx",
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:attune-check"
          ]
        },
        "dryRun": false
      }
    },
    "attune-repair": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework project repair surface. Applies safe deterministic repairs through the stable attune-repair verb when available.",
        "attune": {
          "tier": "public",
          "surface": "repair",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "attune-nx",
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:attune-repair"
          ]
        },
        "dryRun": false
      }
    }
  }
}
