{
  "name": "joern-effect-properties",
  "version": "0.0.0",
  "description": "Property-based harness package for joern-effect.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "nix"
  ],
  "dependencies": {
    "@axiomhq/js": "^1.7.0",
    "@attune/framework-protocol": "workspace:*",
    "effect": "^3.16.12",
    "fast-check": "^3.23.2",
    "joern-effect": "workspace:*",
    "oxc-parser": "^0.135.0",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  }
}
