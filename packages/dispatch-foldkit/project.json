{
  "name": "dispatch-foldkit",
  "root": "packages/dispatch-foldkit",
  "sourceRoot": "packages/dispatch-foldkit/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "packages/dispatch-foldkit",
        "command": "../../node_modules/.bin/tsup src/index.ts --format esm,cjs --dts --sourcemap --clean"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/dispatch-foldkit",
        "command": "../../node_modules/.bin/tsgo --noEmit"
      }
    },
    "typecheck:classic": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/dispatch-foldkit",
        "command": "../../node_modules/.bin/tsc --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node_modules/.bin/oxlint --config root-oxlintrc.json packages/dispatch-foldkit --quiet"
      }
    },
    "test": {
      "dependsOn": [],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/dispatch-foldkit",
        "command": "../../node_modules/.bin/vitest run"
      }
    }
  }
}
