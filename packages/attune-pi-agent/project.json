{
  "name": "attune-pi-agent",
  "root": "packages/attune-pi-agent",
  "sourceRoot": "packages/attune-pi-agent/src",
  "targets": {
    "build": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "targetProject": "attune-pi-agent",
        "tool": "bundler",
        "action": "build",
        "toolId": "tsup",
        "parameters": {
          "entryPoints": [
            "src/index.ts",
            "src/pi-extension.ts",
            "src/generators/spec/generator.ts",
            "src/generators/permission-policy/generator.ts",
            "src/generators/test-obligation/generator.ts",
            "src/generators/taskplane-task/generator.ts"
          ],
          "format": "esm,cjs",
          "dts": true,
          "sourcemap": true,
          "clean": true
        },
        "dryRun": false
      }
    },
    "typecheck": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "attune-pi-agent",
        "checks": [
          "typecheck"
        ],
        "dryRun": false
      }
    },
    "typecheck:classic": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "targetProject": "attune-pi-agent",
        "tool": "typescript",
        "action": "check",
        "toolId": "tsc",
        "parameters": {
          "classic": true
        },
        "dryRun": false
      }
    },
    "lint": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "attune-pi-agent",
        "checks": [
          "lint"
        ],
        "dryRun": false
      }
    },
    "test": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "attune-pi-agent",
        "checks": [
          "test"
        ],
        "dryRun": false
      }
    },
    "property": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "targetProject": "attune-pi-agent",
        "tool": "test-runner",
        "action": "test",
        "toolId": "vitest",
        "parameters": {
          "files": [
            "test/*.property.test.ts"
          ]
        },
        "evidenceOutputs": [
          ".attune/cache/property-evidence/attune-pi-agent"
        ],
        "dryRun": false
      }
    },
    "mutation": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "targetProject": "attune-pi-agent",
        "tool": "mutation",
        "action": "mutate",
        "toolId": "stryker",
        "parameters": {
          "config": "stryker.conf.json"
        },
        "resourceTier": "heavy",
        "evidenceOutputs": [
          ".attune/cache/mutation/attune-pi-agent"
        ],
        "dryRun": false
      }
    }
  }
}
