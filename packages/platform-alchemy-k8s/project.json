{
  "name": "platform-alchemy-k8s",
  "root": "packages/platform-alchemy-k8s",
  "sourceRoot": "packages/platform-alchemy-k8s/src",
  "targets": {
    "build": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "tool": "bundler",
        "action": "build",
        "toolId": "tsup",
        "parameters": {
          "entryPoints": [
            "src/index.ts",
            "src/provider/alchemy-resource.ts"
          ],
          "format": "esm,cjs",
          "dts": true,
          "sourcemap": true,
          "clean": true
        },
        "dryRun": false
      }
    },
    "typecheck": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "checks": [
          "typecheck"
        ],
        "dryRun": false
      }
    },
    "typecheck:classic": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "tool": "typescript",
        "action": "check",
        "toolId": "tsc",
        "parameters": {
          "classic": true
        },
        "dryRun": false
      }
    },
    "lint": {
      "executor": "@attune/nx:package-check",
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "checks": [
          "lint"
        ],
        "dryRun": false
      }
    },
    "generate-crd-types": {
      "executor": "@attune/nx:toolchain",
      "inputs": [
        "{projectRoot}/src/crds/**/*.ts",
        "{projectRoot}/scripts/generate-crd-types.ts"
      ],
      "outputs": [
        "{projectRoot}/src/generated/crds.ts",
        "{projectRoot}/src/generated/crds"
      ],
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "tool": "kubernetes",
        "action": "generate",
        "toolId": "platform-alchemy-k8s:generation-stage",
        "parameters": {
          "stage": "emit-generated",
          "tmpDir": true
        },
        "dryRun": false
      }
    },
    "emit-crd-manifests": {
      "executor": "@attune/nx:toolchain",
      "inputs": [
        "{projectRoot}/src/crds/**/*.ts",
        "{projectRoot}/scripts/generate-crd-types.ts"
      ],
      "outputs": [
        "{projectRoot}/src/generated/crds"
      ],
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "tool": "kubernetes",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "emit-crd-manifests",
          "tmpDir": true
        },
        "dryRun": false
      }
    },
    "emit-crd-types": {
      "executor": "@attune/nx:toolchain",
      "inputs": [
        "{projectRoot}/src/crds/**/*.ts",
        "{projectRoot}/scripts/generate-crd-types.ts"
      ],
      "outputs": [
        "{projectRoot}/src/generated/crds.ts"
      ],
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "tool": "kubernetes",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "emit-crd-types",
          "tmpDir": true
        },
        "dryRun": false
      }
    },
    "emit-generated": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/generated/crds.ts",
        "{projectRoot}/src/generated/crds"
      ],
      "options": {
        "tool": "workspace",
        "action": "check",
        "toolId": "platform-alchemy-k8s-emit-generated",
        "parameters": {
          "targets": [
            "platform-alchemy-k8s:emit-crd-manifests",
            "platform-alchemy-k8s:emit-crd-types"
          ]
        },
        "dryRun": false
      }
    },
    "sync-k8s-resources": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/resources/ResourceRegistry.generated.ts"
      ],
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "tool": "kubernetes",
        "action": "generate",
        "toolId": "generation-stage",
        "parameters": {
          "stage": "sync-k8s-resources",
          "tmpDir": true
        },
        "dryRun": false
      }
    },
    "generate": {
      "executor": "@attune/nx:toolchain",
      "outputs": [
        "{projectRoot}/src/generated/crds.ts",
        "{projectRoot}/src/generated/crds",
        "{projectRoot}/src/resources/ResourceRegistry.generated.ts"
      ],
      "options": {
        "tool": "workspace",
        "action": "check",
        "toolId": "platform-alchemy-k8s-generate",
        "parameters": {
          "targets": [
            "platform-alchemy-k8s:emit-generated",
            "platform-alchemy-k8s:sync-k8s-resources"
          ]
        },
        "dryRun": false
      }
    },
    "check-generated": {
      "executor": "@attune/nx:generated",
      "dependsOn": [
        "generate"
      ],
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "operation": "check",
        "artifact": "generator-shape",
        "outputs": [
          "packages/platform-alchemy-k8s/src/generated/crds.ts",
          "packages/platform-alchemy-k8s/src/generated/crds",
          "packages/platform-alchemy-k8s/src/resources/ResourceRegistry.generated.ts"
        ],
        "provenance": {
          "generatorName": "platform-alchemy-k8s:generationStage",
          "owner": "platform-alchemy-k8s"
        },
        "dryRun": false
      }
    },
    "test": {
      "executor": "@attune/nx:package-check",
      "dependsOn": [
        "generate"
      ],
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "checks": [
          "test"
        ],
        "dryRun": false
      }
    },
    "attune-check": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework project check surface. Runs workspace diagnostics through the stable attune-check verb.",
        "attune": {
          "tier": "public",
          "surface": "check"
        }
      },
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:attune-check"
          ]
        },
        "dryRun": false
      }
    },
    "attune-repair": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework project repair surface. Applies safe deterministic repairs through the stable attune-repair verb when available.",
        "attune": {
          "tier": "public",
          "surface": "repair",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "platform-alchemy-k8s:attune:repair-registry",
            "platform-alchemy-k8s:attune:repair-properties",
            "platform-alchemy-k8s:attune:repair-type-guidance",
            "platform-alchemy-k8s:attune:repair-evidence",
            "platform-alchemy-k8s:attune:repair-generated"
          ]
        },
        "dryRun": false
      }
    },
    "attune:repair-registry": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for operation registry. Public agents should prefer platform-alchemy-k8s:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "registry",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "platform-alchemy-k8s",
          "kind": "registry"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/platform-alchemy-k8s/attune-operation-registry.ts"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/platform-alchemy-k8s/attune-operation-registry.ts"
      ]
    },
    "attune:repair-properties": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for property registry. Public agents should prefer platform-alchemy-k8s:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "properties",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "platform-alchemy-k8s",
          "kind": "properties"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/platform-alchemy-k8s/attune-property-registry.ts"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/platform-alchemy-k8s/attune-property-registry.ts"
      ]
    },
    "attune:repair-type-guidance": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for type-guidance. Public agents should prefer platform-alchemy-k8s:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "type-guidance",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "platform-alchemy-k8s",
          "kind": "type-guidance"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/platform-alchemy-k8s/attune-type-guidance.ts"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/platform-alchemy-k8s/attune-type-guidance.ts"
      ]
    },
    "attune:repair-evidence": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for evidence scaffold. Public agents should prefer platform-alchemy-k8s:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "evidence",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "platform-alchemy-k8s",
          "kind": "evidence"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/platform-alchemy-k8s/attune-property-evidence.ts"
        ],
        "evidenceOutputs": [
          ".attune/cache/evidence/platform-alchemy-k8s/evidence-scaffold.json"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/platform-alchemy-k8s/attune-property-evidence.ts",
        "{workspaceRoot}/.attune/cache/evidence/platform-alchemy-k8s/evidence-scaffold.json"
      ]
    },
    "attune:repair-generated": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Internal Attune Framework repair for generated freshness. Public agents should prefer platform-alchemy-k8s:attune-repair unless a diagnostic names this target.",
        "attune": {
          "tier": "internal",
          "surface": "repair",
          "repairKind": "generated",
          "safeOnly": true
        }
      },
      "options": {
        "targetProject": "platform-alchemy-k8s",
        "tool": "architecture",
        "action": "generate",
        "toolId": "attune-repair",
        "parameters": {
          "allSafe": true,
          "project": "platform-alchemy-k8s",
          "kind": "generated"
        },
        "dryRun": false,
        "outputs": [
          ".attune/cache/generated/platform-alchemy-k8s/generated-freshness.json"
        ]
      },
      "outputs": [
        "{workspaceRoot}/.attune/cache/generated/platform-alchemy-k8s/generated-freshness.json"
      ]
    }
  }
}
