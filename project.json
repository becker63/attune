{
  "name": "workspace",
  "root": ".",
  "targets": {
    "lint": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "root-lint",
        "parameters": {},
        "dryRun": false
      }
    },
    "check": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:policy-fast"
          ]
        },
        "dryRun": false
      }
    },
    "attune-check": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework check surface for package declarations, generated materialization, framework diagnostics, no-report policy, and import boundaries."
      },
      "options": {
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:package-contracts-check"
          ]
        },
        "dryRun": false
      }
    },
    "attune-repair": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Public Attune Framework repair/materialization surface. Runs deterministic framework materialization and diagnostics without raw shell or checked-in reports."
      },
      "options": {
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:package-contracts-check"
          ]
        },
        "dryRun": false
      }
    },
    "source-bom-check": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "source-bom",
        "parameters": {},
        "dryRun": false
      }
    },
    "shape-conformance": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Effect Schema-backed generator shape inventory and Source BOM conformance check."
      },
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "shape-conformance",
        "parameters": {},
        "dryRun": false
      }
    },
    "package-contracts-check": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Focused diagnostic target for package contract/source ownership and generator shape conformance during the Effect package-contract migration.",
        "attune": {
          "runtimeChecks": [
            "descriptor-decode",
            "descriptor-hash",
            "generated-artifact-hash",
            "internal-protocol-delta-diagnostics",
            "waiver-state",
            "import-boundary",
            "local-cache",
            "no-checked-in-report"
          ],
          "readModel": "ProtocolQuery"
        }
      },
      "options": {
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:source-bom-check",
            "workspace:shape-conformance",
            "workspace:framework-policy-check"
          ]
        },
        "dryRun": false
      }
    },
    "atom-graph-conformance": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Cheap deterministic package atom/Reactivity graph conformance diagnostics."
      },
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "framework-policy",
        "parameters": {
          "only": "atom-graph"
        },
        "dryRun": false
      }
    },
    "property-evidence": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Cheap deterministic property evidence and worker target metadata diagnostics."
      },
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "framework-policy",
        "parameters": {
          "only": "property-evidence"
        },
        "dryRun": false
      }
    },
    "coverage-conformance": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Cheap deterministic package coverage guidance conformance diagnostics."
      },
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "framework-policy",
        "parameters": {
          "only": "coverage-conformance"
        },
        "dryRun": false
      }
    },
    "framework-policy-check": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Focused framework import-boundary and no checked-in protocol report policy check."
      },
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "framework-policy",
        "parameters": {},
        "dryRun": false
      }
    },
    "policy-install-hooks": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Install the repo-owned Nix/Nx Git hooks for commit and push validation."
      },
      "options": {
        "tool": "workspace",
        "action": "install",
        "toolId": "git-hooks",
        "parameters": {},
        "dryRun": false
      }
    },
    "policy-commit": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Default pre-commit policy gate; composes through workspace:policy-fast."
      },
      "options": {
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:policy-fast"
          ]
        },
        "dryRun": false
      }
    },
    "policy-push": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Default pre-push policy gate; heavy/manual push campaigns use workspace:policy-proof-pressure."
      },
      "options": {
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:policy-fast"
          ]
        },
        "dryRun": false
      }
    },
    "arch:scan": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Low-level architecture scanner used by workspace policy targets. Public workflows should use workspace:policy-fast, workspace:policy-proof-pressure, or workspace:package-contracts-check."
      },
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "scan",
        "parameters": {},
        "dryRun": false
      }
    },
    "arch:deps": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "deps",
        "parameters": {},
        "dryRun": false
      }
    },
    "arch:cycles": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "cycles",
        "parameters": {},
        "dryRun": false
      }
    },
    "arch:unused": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "unused",
        "parameters": {},
        "dryRun": false
      }
    },
    "arch:complexity": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "complexity",
        "parameters": {},
        "dryRun": false
      }
    },
    "arch:duplicates": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "duplicates",
        "parameters": {},
        "dryRun": false
      }
    },
    "arch:types": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "types",
        "parameters": {},
        "dryRun": false
      }
    },
    "arch:churn": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "churn",
        "parameters": {},
        "dryRun": false
      }
    },
    "arch:mutation": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Explicit mutation-pressure architecture gate. Only workspace:policy-proof-pressure invokes this target."
      },
      "options": {
        "tool": "architecture",
        "action": "mutate",
        "toolId": "stryker",
        "parameters": {
          "config": "stryker.conf.json"
        },
        "resourceTier": "heavy",
        "evidenceOutputs": [
          ".attune/cache/mutation/workspace-architecture"
        ],
        "dryRun": false
      }
    },
    "policy-proof-pressure": {
      "executor": "@attune/nx:toolchain",
      "metadata": {
        "description": "Heavy/manual proof-pressure surface for property, Joern, fuzz, mutation, coverage, and architecture campaigns."
      },
      "options": {
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:package-contracts-check",
            "workspace:atom-graph-conformance",
            "workspace:property-evidence",
            "workspace:coverage-conformance",
            "attune-architecture:test",
            "workspace:arch:scan",
            "workspace:arch:deps",
            "workspace:arch:cycles",
            "workspace:arch:complexity",
            "workspace:arch:duplicates",
            "workspace:arch:types",
            "workspace:arch:churn",
            "effect-oxlint-policy:test",
            "effect-oxlint-policy:build",
            "joern-effect-properties:property",
            "joern-effect-properties:property-joern",
            "joern-effect-properties:fuzz:smoke",
            "attune-pi-agent:property",
            "attune-pi-agent:mutation",
            "workspace:arch:mutation"
          ],
          "effectOxlintPolicy": true
        },
        "dryRun": false
      }
    },
    "policy-fast": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "attune-nx:test",
            "workspace:package-contracts-check",
            "workspace:atom-graph-conformance",
            "workspace:property-evidence",
            "workspace:coverage-conformance",
            "attune-architecture:test",
            "workspace:arch:scan",
            "workspace:arch:deps",
            "workspace:arch:cycles",
            "workspace:arch:complexity",
            "workspace:arch:duplicates",
            "workspace:arch:types",
            "workspace:arch:churn",
            "effect-oxlint-policy:test",
            "effect-oxlint-policy:build"
          ],
          "graphFile": "/tmp/attune-nx-graph.json",
          "effectOxlintPolicy": true,
          "verifyPrCompletion": true
        },
        "dryRun": false
      }
    },
    "policy-all": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "tool": "workspace",
        "action": "check",
        "toolId": "nx-targets",
        "parameters": {
          "targets": [
            "workspace:policy-push",
            "workspace:policy-proof-pressure"
          ]
        },
        "dryRun": false
      }
    },
    "codex-audit-prs": {
      "executor": "@attune/nx:toolchain",
      "options": {
        "tool": "architecture",
        "action": "check",
        "toolId": "codex-audit-prs",
        "parameters": {},
        "dryRun": false
      }
    }
  }
}
