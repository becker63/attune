{
  "name": "workspace",
  "root": ".",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/codex/pnpm.mjs exec oxlint --config root-oxlintrc.json package.json project.json nx.json tsconfig.base.json packages --quiet"
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "node scripts/codex/pnpm.mjs exec nx run-many -t lint,typecheck --all",
          "openspec validate --all --no-interactive"
        ],
        "parallel": false
      }
    },
    "policy-architecture": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "./node_modules/.bin/nx run effect-oxlint-policy:build",
          "./node_modules/.bin/oxlint --config oxlint/effect-oxlint-policy.json package.json project.json nx.json tsconfig.base.json packages --quiet"
        ],
        "parallel": false
      }
    },
    "policy-fast": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "./node_modules/.bin/nx run effect-oxlint-policy:test",
          "./node_modules/.bin/nx run workspace:policy-architecture"
        ],
        "parallel": false
      }
    }
  }
}
