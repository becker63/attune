{
  "$schema": "http://json-schema.org/schema",
  "$id": "SyncCocoIndexMcpToolsGeneratorSchema",
  "title": "Sync CocoIndex MCP Tools",
  "type": "object",
  "properties": {
    "directory": {
      "type": "string",
      "description": "Directory containing CocoIndex MCP tool modules.",
      "default": "src/cocoindex/tools"
    },
    "registry": {
      "type": "string",
      "description": "Generated MCP tool registry file."
    },
    "export": {
      "type": "boolean",
      "description": "Update an index.ts barrel in the tool directory.",
      "default": true
    }
  },
  "additionalProperties": false
}
