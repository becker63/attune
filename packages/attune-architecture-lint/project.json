{
  "name": "attune-architecture-lint",
  "root": "packages/attune-architecture-lint",
  "sourceRoot": "packages/attune-architecture-lint/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "packages/attune-architecture-lint",
        "command": "../../node_modules/.bin/tsc -p tsconfig.build.json"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/attune-architecture-lint",
        "command": "../../node_modules/.bin/tsc --noEmit"
      }
    },
    "typecheck:classic": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/attune-architecture-lint",
        "command": "../../node_modules/.bin/tsc --noEmit"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/attune-architecture-lint",
        "command": "../../node_modules/.bin/vitest run"
      }
    }
  }
}
